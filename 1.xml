var YaGames = { init: function() { return Promise.resolve(ysdk); } };

// ================================================================
// PART BIRLESTIRME (data.br: 6 part, wasm.br: 6 part)
// ================================================================
var splitFiles = {
    "Build.data.br": 6,
    "Build.wasm.br": 6
};
var mergedFileCache = {};

async function downloadAndMergeParts(fileName, partCount) {
    var parts = [], totalLoaded = 0;
    for (var i = 0; i < partCount; i++) {
        var resp = await fetch("https://cdn.jsdelivr.net/gh/RyGuy1371/dareal-swin@main/Build/parts/" + fileName + ".part" + i);
        if (!resp.ok) throw new Error("Part hata: " + fileName + ".part" + i + " (" + resp.status + ")");
        var ab = await resp.arrayBuffer();
        parts.push(new Uint8Array(ab));
        totalLoaded += ab.byteLength;
        console.log("  [" + fileName + "] Part " + (i+1) + "/" + partCount + " (" + (totalLoaded/1048576).toFixed(1) + " MB)");
    }
    var totalSize = parts.reduce(function(s,p){ return s+p.length; }, 0);
    var merged = new Uint8Array(totalSize);
    var offset = 0;
    for (var j = 0; j < parts.length; j++) { merged.set(parts[j], offset); offset += parts[j].length; }
    console.log("%c[Merger] " + fileName + ": " + (totalSize/1048576).toFixed(1) + " MB OK", "color:#73FF73;background:#454545");
    return merged.buffer;
}

async function mergeAllSplitFiles() {
    var fns = Object.keys(splitFiles);
    for (var i = 0; i < fns.length; i++) {
        console.log("%c[Merger] " + fns[i] + " (" + splitFiles[fns[i]] + " part)...", "color:#73DFFF;background:#454545");
        mergedFileCache[fns[i]] = await downloadAndMergeParts(fns[i], splitFiles[fns[i]]);
    }
    console.log("%c[Merger] Tamamlandi!", "color:#73FF73;background:#454545");
}

// FETCH OVERRIDE
var originalFetch = window.fetch.bind(window);
window.fetch = function(input, init) {
    var url = (typeof input === "string") ? input : (input && input.url ? input.url : "");
    var keys = Object.keys(mergedFileCache);
    for (var i = 0; i < keys.length; i++) {
        if (url.indexOf(keys[i]) !== -1 && mergedFileCache[keys[i]]) {
            var buf = mergedFileCache[keys[i]];
            return Promise.resolve(new Response(buf, {
                status:200, statusText:"OK",
                headers:{ "Content-Type":"application/octet-stream", "Content-Length":buf.byteLength.toString() }
            }));
        }
    }
    return originalFetch(input, init);
};

// XHR OVERRIDE
var OrigXHR = window.XMLHttpRequest;
window.XMLHttpRequest = function PatchedXHR() {
    var xhr = new OrigXHR();
    var origOpen = xhr.open.bind(xhr), origSend = xhr.send.bind(xhr), intercepted = null;
    xhr.open = function(method, url) {
        intercepted = null;
        if (typeof url === "string") {
            var keys = Object.keys(mergedFileCache);
            for (var i = 0; i < keys.length; i++) {
                if (url.indexOf(keys[i]) !== -1 && mergedFileCache[keys[i]]) { intercepted = keys[i]; break; }
            }
        }
        return origOpen.apply(xhr, arguments);
    };
    xhr.send = function(body) {
        if (intercepted) {
            var buf = mergedFileCache[intercepted];
            Object.defineProperty(xhr, "status", { get:function(){ return 200; } });
            Object.defineProperty(xhr, "statusText", { get:function(){ return "OK"; } });
            Object.defineProperty(xhr, "readyState", { get:function(){ return 4; } });
            Object.defineProperty(xhr, "response", { get:function(){ return buf; } });
            setTimeout(function() {
                if (xhr.onreadystatechange) xhr.onreadystatechange();
                if (xhr.onload) xhr.onload();
                try { xhr.dispatchEvent(new Event("load")); } catch(e) {}
                try { xhr.dispatchEvent(new Event("loadend")); } catch(e) {}
            }, 0);
            return;
        }
        return origSend.apply(xhr, arguments);
    };
    return xhr;
};

// ================================================================
// OYUN KODU
// ================================================================
const hideFullScreenButton = "";
const buildUrl = "https://cdn.jsdelivr.net/gh/RyGuy1371/dareal-swin@main/Build";
